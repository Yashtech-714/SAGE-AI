# ============================================================
# Text-to-SQL AI System — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ── LLM Provider ─────────────────────────────────────────────
# Supports: openai | groq | grok | together | fireworks
#
# GROQ (fastest, free tier, great for demos):
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# OpenAI:
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-openai-key-here
# LLM_BASE_URL=
# LLM_MODEL=gpt-4o-mini

# Grok / X.AI:
# LLM_PROVIDER=grok
# LLM_API_KEY=xai-your-key-here
# LLM_BASE_URL=https://api.x.ai/v1
# LLM_MODEL=grok-3-mini

# ── Database ──────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./datasets/olist.db
DATASET_DIR=./Dataset

# PostgreSQL (production upgrade):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nl2sql

# ── Application ───────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
LOG_DIR=./logs

# ── AI Pipeline ───────────────────────────────────────────────
MAX_QUERY_RETRIES=3
MAX_RESULT_ROWS=500
MAX_CONTEXT_TABLES=5
