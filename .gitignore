# ============================================================
# .gitignore — Text-to-SQL AI System
# ============================================================

# ── Secrets (NEVER commit) ────────────────────────────────────
.env
.env.local
.env.production
*.key
secrets/

# ── Dataset (too large for GitHub — download separately) ─────
datasets/*.db
datasets/*.csv
datasets/*.zip
Dataset/

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.whl
MANIFEST

# ── Virtual Environments ──────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# ── Logs & Runtime ────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Node.js / Frontend ────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
node_modules/

# ── Vite / Build Artifacts ────────────────────────────────────
frontend/.vite/
*.local

# ── IDE & OS ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini
*.orig

# ── Testing ───────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── SQLite WAL files ──────────────────────────────────────────
*.db-shm
*.db-wal

# ── Gemini/AI workspace ───────────────────────────────────────
.gemini/
